{
    "data":{
        "HP#data":{"value":30,"max":110},
        "Ability Scores":{
            "Strength":{
                "score#data":{"value":10,"max":20},
                "mod": "=floor(data('.score')/2)-5",
                "save": "=data('.mod')"
            }
        },
        "Some Data":{
            "mutliNode#data":[
                {"value":10},
                {"value":20},
                {"value":30}
            ],
            "sideNode":"=data('multiNode.1')"
        },
        "Equipment":{
            "capacity":"=data('Stats.Strength.score') * 15",
            "items":[
                {
                    "name":"Shortsword",
                    "desc":"blablabla",
                    "equipped":false
                },
                {
                    "name":"Shield",
                    "desc":"blablabla",
                    "equipped":false
                },
                {
                    "desc":"no name"
                }
            ]
        },
        "constructor":"malicious code",
        "Modifiers":{
            "Save Increase#modifier":{
                "targets":["Ability Scores.*.save"],
                "conditions":["items.*.equipped"]
            }
        }
    }
}