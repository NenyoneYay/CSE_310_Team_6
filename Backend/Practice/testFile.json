{
    "data":{
        "HP#data":{"value":30,"max":110},
        "Speed#data":{"value": 30, "max": 100},
        "Ability Scores":{
            "Strength":{
                "score#data":{"value":10,"max":20,"min":0},
                "mod": "=floor(data('.score')/2)-5",
                "save": "=data('.mod')"
            },
            "Dexterity":{
                "score#data":{"value":15,"max":20,"min":0},
                "mod": "=floor(data('.score')/2)-5",
                "save": "=data('.mod')"
            },
            "Constitution":{
                "score#data":{"value":13,"max":20,"min":0},
                "mod": "=floor(data('.score')/2)-5",
                "save": "=data('.mod')"
            },
            "Intelligence":{
                "score#data":{"value":18,"max":20,"min":0},
                "mod": "=floor(data('.score')/2)-5",
                "save": "=data('.mod')"
            },
            "Wisdom":{
                "score#data":{"value":11,"max":20,"min":0},
                "mod": "=floor(data('.score')/2)-5",
                "save": "=data('.mod')"
            },
            "Charisma":{
                "score#data":{"value":8,"max":20,"min":0},
                "mod": "=floor(data('.score')/2)-5",
                "save": "=data('.mod')"
            }
        },
        "Some Data":{
            "multiNode#data":[
                {"value":10},
                {"value":20},
                {"value":30}
            ],
            "sideNode":"=data('.multiNode.1')"
        },
        "Equipment":{
            "capacity":"=data('Ability Scores.Strength.score') * 15",
            "items":[
                {
                    "name":"Shortsword",
                    "desc":"blablabla",
                    "equipped":true,
                    "weight":5
                },
                {
                    "name":"Shield",
                    "desc":"blablabla",
                    "equipped":false,
                    "weight":3
                },
                {
                    "desc":"no name",
                    "weight":40
                }
            ],
            "carrying":"=sum(aprod(data('Equipment.items[*].weight'),data('Equipment.items[*].equipped',1)))"
        },
        "constructor":"malicious code",
        "Modifiers":{
            "Save Increase#modifier":{
                "targets":["Ability Scores.*.save"],
                "conditions":["items.*.equipped"]
            }
        },
        "Classes":{
            "Warlock":{
                "Traits":{
                    "Gift of Strength":{
                        "desc":"bla",
                        "Strength Boost#modifier":{
                            "target":"Ability Scores.Strength.score",
                            "operation":"add",
                            "value":5
                        },
                        "Super boost#modifer":{
                            "target":"Ability Scores.Strength.score#value,max",
                            "operation":"replace",
                            "tier":20000000,
                            "value":19
                        }
                    }
                }
            }
        },
        "Race":{
            "Elf":{
                "Traits":{
                    "Speed#modifier":{
                        "target": "Speed",
                        "operation":"replace",
                        "value":30,
                        "conditions":["= map(data(\"Equipment.items[*].(type,equipped)\",false), 'x[1] ? x[0] : [PLACEHOLDER NEEDS TO BE EMPTY STRING]')"],
                        "asdf":       "      [['armor',true],['armor',false],['Shield',true],[undefined,false]] => ['armor',true]"
                    },
                    "Elf Dexterity":{
                        "desc": "blablabla",
                        "Dexterity Boost#modifier":{
                            "target": "Ability Scores.Dexterity.score",
                            "operation": "add",
                            "value": 2
                        }

                    }
                }
            }
        }
    }
}